# Dependencies
node_modules/

# Build output
dist/

# Test artifacts
allure-results/
allure-report/
test-results/
playwright-report/
.bdd-generated/
.claude/
.playwright/
.playwright-mcp/

# GitHub Actions — temporary, will add back before publishing
.github/workflows/

# Visual regression — environment-specific baselines are committed,
# but raw OS snapshot caches are not
*.snap

# Logs
*.log
npm-debug.log*

# Environment secrets — NEVER commit actual secrets
.env
.env.*
!.env.example
config/env/dev.json
config/env/prod.json
config/env/staging.json

# Visual regression — environment-specific baselines are committed,
# but raw OS snapshot caches are not
snapshots/dev/features/
*.snap

# macOS
**/.DS_Store

# Editor
.vscode/settings.json
.idea/

# ---- Files that MUST be committed ----
# snapshots/ — baseline images generated on a stable reference environment
# config/env/*.json — safe: all secrets are ${VAR} references, not plain values
